# Bridge dependencies
lucid_discord_bridge/node_modules/

# Bridge config (contains real tokens & API keys — never commit this)
lucid_discord_bridge/config.json

# Bridge auth tokens (issued client codes — never commit)
lucid_discord_bridge/tokens.json

# Bridge log files
lucid_discord_bridge/logs/

# Local debug captures (Discord HTML dumps)
# Specific names so we don't accidentally ignore legitimate extension HTML
# files like popup.html / offscreen.html.
lucid_redeemer/leo.html
lucid_redeemer/stage_chat.html
lucid_redeemer/*_dump.html

# OS files
.DS_Store
Thumbs.db
